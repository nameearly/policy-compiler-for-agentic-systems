% ================================================================
% PCAS Policy: Compensation Strategy Document Access Control
%
% Scenario: A "group agent" session has access to sensitive HR
% documents. Only VP-level principals may read them.
%
% Policy enforces:
%   1. Direct read access requires VP role.
%   2. Taint propagates through the dependency graph: any result
%      derived from a sensitive document is itself tainted.
%   3. Any action by a non-VP that (directly or indirectly) depends
%      on tainted content is denied — catching indirect leakage.
% ================================================================

% --- EDB: Sensitive documents ---
SensitiveDoc(compensation_strategy).
SensitiveDoc(board_presentation).        % second sensitive doc — for isolation test

% ================================================================
% STRATUM 1: Allowed (direct access grants)
% ================================================================

% Any authenticated entity may list available documents (listing
% reveals only names, not content — not a sensitive operation).
Allowed(Entity, list_documents, all) :-
    EntityRole(Entity, _),
    PendingAction(_, list_documents, Entity).

% A VP may read any sensitive document directly.
Allowed(Entity, read_document, Doc) :-
    EntityRole(Entity, vp),
    SensitiveDoc(Doc),
    ActionArg(_, doc_id, Doc),
    PendingAction(_, read_document, Entity).

% Any entity may read non-sensitive documents.
Allowed(Entity, read_document, Doc) :-
    EntityRole(Entity, _),
    not SensitiveDoc(Doc),
    ActionArg(_, doc_id, Doc),
    PendingAction(_, read_document, Entity).

% Any authenticated entity may send emails in general.
% This rule is intentionally broad — the point is that Rule D2 (below)
% overrides it when the action depends on tainted content.
% This lets us prove PCAS blocks Bob's send_email specifically BECAUSE
% of taint, not merely because send_email has no Allowed rule.
Allowed(Entity, send_email, all) :-
    EntityRole(Entity, _),
    PendingAction(_, send_email, Entity).

% ================================================================
% STRATUM 1: Transitive dependency closure
% (Depends = transitive closure of DirectDepends)
% ================================================================

% Base case: a direct graph edge implies Depends.
Depends(Child, Parent) :- DirectDepends(Child, Parent).

% Inductive case: transitivity.
Depends(Child, Ancestor) :-
    Depends(Child, Middle),
    DirectDepends(Middle, Ancestor).

% ================================================================
% STRATUM 1: Taint propagation
% ================================================================

% A tool result is tainted if it directly read a sensitive document.
Tainted(Node) :-
    IsToolResult(Node, read_document, Doc),
    SensitiveDoc(Doc).

% Taint propagates: anything that (transitively) depends on a tainted
% node is itself tainted.
Tainted(Node) :-
    Depends(Node, Ancestor),
    Tainted(Ancestor).

% ================================================================
% STRATUM 2: Denied (violations — deny overrides allow)
% ================================================================

% Rule D1: Non-VP cannot read a sensitive document directly.
Denied(Entity, read_document, no_permission) :-
    PendingAction(_, read_document, Entity),
    ActionArg(_, doc_id, Doc),
    SensitiveDoc(Doc),
    not EntityRole(Entity, vp).

% Rule D2: Non-VP action that (transitively) depends on tainted
% content is denied — catches indirect information leakage.
Denied(Entity, Tool, tainted_dependency) :-
    PendingAction(ActionId, Tool, Entity),
    Depends(ActionId, Ancestor),
    Tainted(Ancestor),
    not EntityRole(Entity, vp).
